---
import IconArchive from "@/assets/icons/IconArchive.svg";

type Props = {
  category: string;
  categorySlug: string;
  size?: "sm" | "lg";
};

const { category, categorySlug, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/categories/${categorySlug}/`}
    transition:name={categorySlug}
    class:list={[
      "flex items-center gap-0.5",
      "border-b-2 border-solid border-foreground",
      "hover:-mt-0.5 hover:border-accent hover:text-accent",
      "focus-visible:border-none focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconArchive
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {category}
  </a>
</li>
